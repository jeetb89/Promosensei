# ─────────────────────────────────────────────
#  Promo Sensei — Environment Variables
#  Copy this file to .env and fill in the values
# ─────────────────────────────────────────────

# ── OpenAI ───────────────────────────────────
# Your OpenAI API key.
# Used for: generating embeddings (text-embedding-ada-002) and
#           LLM responses (GPT-4) in all search and summary commands.
# Get it from: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-...

# ── Slack ─────────────────────────────────────
# Bot OAuth token — authorises the bot to post messages and respond to commands.
# Starts with xoxb-
# Get it from: Slack App dashboard → OAuth & Permissions → Bot User OAuth Token
SLACK_BOT_TOKEN=xoxb-...

# App-level token — required for Socket Mode (real-time event delivery without a public URL).
# Starts with xapp-
# Get it from: Slack App dashboard → Basic Information → App-Level Tokens
SLACK_APP_TOKEN=xapp-...

# ── ChromaDB (optional) ───────────────────────
# When CHROMA_HOST is set, the app connects to a remote ChromaDB HTTP server
# (e.g. the chromadb Docker container).
# When left empty, the app uses a local persistent store at ./chroma_store/
CHROMA_HOST=
CHROMA_PORT=8000
